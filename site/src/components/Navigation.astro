---
const pathname = Astro.url.pathname;

interface NavItem {
  label: string;
  href: string;
  children?: { label: string; href: string; description?: string }[];
}

const navItems: NavItem[] = [
  {
    label: "Research",
    href: "/research/",
    children: [
      { label: "All Studies", href: "/research/", description: "Research hub" },
      { label: "Jailbreak Archaeology", href: "/research/jailbreak-archaeology/", description: "64 scenarios, 6 eras" },
      { label: "Multi-Agent", href: "/research/moltbook/", description: "Moltbook analysis" },
      { label: "Attack Taxonomy", href: "/research/attack-taxonomy/", description: "81 techniques" },
      { label: "Defense Patterns", href: "/research/defense-patterns/", description: "How models resist" },
      { label: "Humanoid Safety", href: "/research/humanoid-safety/", description: "Platform failure mapping" },
      { label: "Failure Modes", href: "/research/failure-modes/", description: "Taxonomy of AI failures" },
      { label: "Company Directory", href: "/research/directory/", description: "214 robotics companies" },
      { label: "AI Safety Orgs", href: "/research/ai-safety-orgs/", description: "117 safety organisations" },
      { label: "Research Reports", href: "/research/reports/", description: "Published research findings" },
      { label: "Legal Analysis", href: "/research/legal/", description: "AI safety legal research" },
      { label: "Papers", href: "/papers/", description: "Academic submissions" },
    ],
  },
  {
    label: "Content",
    href: "/blog/",
    children: [
      { label: "Blog", href: "/blog/", description: "Analysis and commentary" },
      { label: "Daily Paper", href: "/daily-paper/", description: "arXiv paper reviews" },
      { label: "What's New", href: "/new/", description: "Latest across the site" },
    ],
  },
  { label: "Framework", href: "/framework/" },
  {
    label: "Services",
    href: "/services/",
    children: [
      { label: "Red-Team Assessments", href: "/services/red-team-assessments/", description: "Adversarial testing" },
      { label: "Safety Audits", href: "/services/safety-audits/", description: "Compliance evaluation" },
      { label: "Advisory", href: "/services/advisory/", description: "Strategic guidance" },
      { label: "Intelligence Briefs", href: "/services/intelligence-briefs/", description: "Threat landscape" },
      { label: "Policy Briefs", href: "/policy/", description: "Policy analysis" },
      { label: "Capability vs Safety", href: "/policy/capability-safety-spectrum/", description: "Capability-safety analysis" },
      { label: "Embodied AI Safety", href: "/policy/embodied-ai-safety/", description: "Beyond alignment" },
    ],
  },
  {
    label: "About",
    href: "/about/",
    children: [
      { label: "About", href: "/about/", description: "The project" },
      { label: "Our Team", href: "/about/team/", description: "Meet the research team" },
      { label: "Manifesto", href: "/manifesto/", description: "Failure-first philosophy" },
      { label: "Glossary", href: "/glossary/", description: "Key terms defined" },
    ],
  },
  { label: "Search", href: "/search/" },
];

function isActive(href: string, current: string, children?: { href: string }[]): boolean {
  if (href === "/") return current === "/";
  if (current.startsWith(href)) return true;
  if (children) return children.some(c => current.startsWith(c.href));
  return false;
}
---

<nav class="site-nav" aria-label="Main navigation">
  <div class="nav-inner">
    <a href="/" class="nav-brand">
      <span class="nav-brand-icon">&#x2B22;</span>
      <span class="nav-brand-text">Failure-First</span>
    </a>

    <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false" aria-controls="nav-links">
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>

    <ul class="nav-links" id="nav-links" role="list">
      {navItems.map((item) => (
        <li class:list={[{ "has-dropdown": item.children }]}>
          <a
            href={item.href}
            class:list={[{ active: isActive(item.href, pathname, item.children) }]}
            aria-current={isActive(item.href, pathname, item.children) ? "page" : undefined}
            aria-haspopup={item.children ? "true" : undefined}
            aria-expanded={item.children ? "false" : undefined}
          >
            {item.label}
            {item.children && <span class="dropdown-arrow" aria-hidden="true">&#x25BC;</span>}
          </a>
          {item.children && (
            <ul class="dropdown" role="list">
              {item.children.map((child) => (
                <li>
                  <a href={child.href}>
                    <span class="dropdown-label">{child.label}</span>
                    {child.description && <span class="dropdown-desc">{child.description}</span>}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(5, 8, 16, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-subtle);
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3.5rem;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--accent-primary);
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 1.1rem;
    font-weight: 400;
    border-bottom: none;
    letter-spacing: -0.01em;
  }

  .nav-brand:hover {
    border-bottom: none;
  }

  .nav-brand-icon {
    font-size: 1.125rem;
    line-height: 1;
  }

  .nav-links {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-links > li {
    position: relative;
  }

  .nav-links > li > a {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem 0.75rem;
    color: var(--fg-muted);
    font-size: 0.8125rem;
    font-weight: 400;
    border-bottom: none;
    border-radius: 4px;
    transition: color var(--transition-duration) var(--transition-easing),
                background var(--transition-duration) var(--transition-easing);
  }

  .nav-links > li > a:hover {
    color: var(--fg);
    background: rgba(0, 210, 255, 0.05);
    border-bottom: none;
  }

  .nav-links > li > a.active {
    color: var(--accent-primary);
    background: rgba(0, 210, 255, 0.08);
  }

  .dropdown-arrow {
    font-size: 0.5rem;
    opacity: 0.6;
    transition: transform var(--transition-duration) var(--transition-easing);
  }

  /* Dropdown menu */
  .dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 200px;
    background: rgba(5, 8, 16, 0.97);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--border-subtle);
    border-radius: 4px;
    padding: 0.5rem;
    margin-top: 0.25rem;
    list-style: none;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: opacity var(--transition-duration) var(--transition-easing),
                visibility var(--transition-duration) var(--transition-easing),
                transform var(--transition-duration) var(--transition-easing);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
  }

  .has-dropdown:hover .dropdown,
  .has-dropdown:focus-within .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .has-dropdown:hover .dropdown-arrow {
    transform: rotate(180deg);
  }

  .dropdown li {
    margin: 0;
  }

  .dropdown a {
    display: flex;
    flex-direction: column;
    padding: 0.5rem 0.75rem;
    border-radius: 3px;
    border-bottom: none;
    transition: background var(--transition-duration) var(--transition-easing);
  }

  .dropdown a:hover {
    background: rgba(0, 210, 255, 0.08);
    border-bottom: none;
  }

  .dropdown-label {
    color: var(--fg);
    font-size: 0.8125rem;
  }

  .dropdown-desc {
    color: var(--fg-muted);
    font-size: 0.6875rem;
    margin-top: 0.125rem;
  }

  /* Mobile hamburger */
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  .nav-toggle:focus-visible {
    outline: 2px solid var(--accent-primary);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .nav-toggle-bar {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--fg-muted);
    border-radius: 1px;
    transition: transform var(--transition-duration) var(--transition-easing),
                opacity var(--transition-duration) var(--transition-easing);
  }

  @media (max-width: 768px) {
    .nav-toggle {
      display: flex;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: 3.5rem;
      left: 0;
      right: 0;
      flex-direction: column;
      background: rgba(5, 8, 16, 0.97);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border-subtle);
      padding: 0.5rem;
      gap: 0;
    }

    .nav-links.open {
      display: flex;
    }

    .nav-links > li > a {
      padding: 0.75rem 1rem;
    }

    /* Mobile dropdown behavior */
    .dropdown {
      position: static;
      min-width: 100%;
      opacity: 1;
      visibility: visible;
      transform: none;
      background: transparent;
      border: none;
      box-shadow: none;
      margin: 0;
      padding: 0 0 0 1rem;
      display: none;
    }

    .has-dropdown.mobile-open .dropdown {
      display: block;
    }

    .dropdown a {
      padding: 0.5rem 1rem;
    }

    /* Hamburger animation when open */
    .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(1) {
      transform: rotate(45deg) translate(4px, 4px);
    }

    .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(2) {
      opacity: 0;
    }

    .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(3) {
      transform: rotate(-45deg) translate(4px, -4px);
    }
  }
</style>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const links = document.querySelector('.nav-links');
  const dropdownParents = document.querySelectorAll('.has-dropdown');

  if (toggle && links) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      links.classList.toggle('open');
    });

    // Close menu on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && links.classList.contains('open')) {
        links.classList.remove('open');
        toggle.setAttribute('aria-expanded', 'false');
        toggle.focus();
      }
    });

    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
      if (
        links.classList.contains('open') &&
        !links.contains(e.target as Node) &&
        !toggle.contains(e.target as Node)
      ) {
        links.classList.remove('open');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });
  }

  // Desktop: sync aria-expanded with hover/focus-within state
  if (window.matchMedia('(hover: hover)').matches) {
    dropdownParents.forEach((parent) => {
      const link = parent.querySelector(':scope > a');
      if (!link) return;
      parent.addEventListener('mouseenter', () => link.setAttribute('aria-expanded', 'true'));
      parent.addEventListener('mouseleave', () => link.setAttribute('aria-expanded', 'false'));
      parent.addEventListener('focusin', () => link.setAttribute('aria-expanded', 'true'));
      parent.addEventListener('focusout', (e) => {
        if (!parent.contains((e as FocusEvent).relatedTarget as Node)) {
          link.setAttribute('aria-expanded', 'false');
        }
      });
    });
  }

  // Mobile dropdown toggle — first tap opens dropdown, second tap navigates
  dropdownParents.forEach((parent) => {
    const link = parent.querySelector(':scope > a');
    if (link) {
      link.addEventListener('click', (e) => {
        if (window.innerWidth <= 768) {
          if (!parent.classList.contains('mobile-open')) {
            e.preventDefault();
            // Close other open dropdowns
            dropdownParents.forEach((p) => {
              if (p !== parent) {
                p.classList.remove('mobile-open');
                const otherLink = p.querySelector(':scope > a');
                if (otherLink) otherLink.setAttribute('aria-expanded', 'false');
              }
            });
            parent.classList.add('mobile-open');
            link.setAttribute('aria-expanded', 'true');
          }
          // Second tap: allow default navigation to parent href
        }
      });
    }
  });
</script>
