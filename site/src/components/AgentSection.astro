---
/**
 * AgentSection — Full-viewport agent profile section for the team snap-scroll page.
 *
 * Props:
 *   agent   — agent data object (see team.astro agents array)
 *   isFirst — true for the first agent (River Song) — gets preload="auto"
 *   index   — numeric index used for fetchpriority on first two images
 */

interface AgentData {
  name: string;
  role: string;
  slug: string;
  color: string;
  rgb: string;
  photo: string;
  initials: string;
  tagline: string;
  bio: string;
  tags: string[];
  audio: string;
  isCloser?: boolean;
}

interface Props {
  agent: AgentData;
  isFirst?: boolean;
  isCloser?: boolean;
  index: number;
}

const { agent, isFirst = false, isCloser = false, index } = Astro.props;
const { name, role, slug, color, rgb, photo, initials, tagline, bio, tags, audio } = agent;
const sectionId = `agent-${slug}`;
const audioPreload = isFirst ? 'auto' : 'none';
const imgPriority = index < 2 ? 'high' : 'auto';
---

<section
  id={sectionId}
  class="agent-section"
  role="region"
  aria-label={`${name} profile`}
  data-accent-rgb={rgb}
  data-accent-color={color}
  data-agent-slug={slug}
>
  <div class="agent-bg-gradient" style={`--agent-color: ${color}`} aria-hidden="true"></div>

  <div class="agent-content-wrap">
    <div class="agent-scrim">
      <!-- Photo -->
      <div class="agent-photo-wrap">
        <img
          src={photo}
          alt={`${name}, ${role}`}
          class="agent-photo"
          style={`--agent-color: ${color}`}
          loading={index < 2 ? 'eager' : 'lazy'}
          fetchpriority={imgPriority}
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        />
        <div class="agent-photo-fallback" style={`--agent-color: ${color}`} aria-hidden="true">
          {initials}
        </div>
      </div>

      <!-- Name + Role badge -->
      <div class="agent-identity">
        <h2 class="agent-name" style={`color: ${color}`}>{name}</h2>
        <div class="agent-role-badge" style={`--agent-color: ${color}`}>{role}</div>
      </div>

      <!-- Tagline -->
      <p class="agent-tagline">{tagline}</p>

      <!-- Bio -->
      <p class="agent-bio">{bio}</p>

      <!-- Tags -->
      <div class="agent-tags" aria-label="Contribution areas">
        {tags.map((tag) => (
          <span class="agent-tag" style={`--agent-color: ${color}`}>{tag}</span>
        ))}
      </div>

      {/* CTA moved to standalone section in team.astro */}
    </div>
  </div>

  <!-- Audio (hidden element — controlled by JS) -->
  <audio
    data-agent={slug}
    preload={audioPreload}
    aria-label={`${name} voice introduction`}
  >
    <source src={`/audio/companions/${audio}.ogg`} type="audio/ogg; codecs=opus" />
    <source src={`/audio/companions/${audio}.mp3`} type="audio/mpeg" />
  </audio>

  <!-- Audio control button (always visible — WCAG 1.4.2) -->
  <div class="audio-indicator" data-agent={slug}>
    <button
      class="audio-btn"
      type="button"
      aria-label={`Play ${name} voice intro`}
      aria-pressed="false"
      data-agent={slug}
      style={`--agent-color: ${color}`}
    >
      <svg class="icon-play" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" width="14" height="14">
        <path d="M5 4l12 6-12 6V4z"/>
      </svg>
      <svg class="icon-pause" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" width="14" height="14">
        <rect x="4" y="3" width="4" height="14" rx="1"/>
        <rect x="12" y="3" width="4" height="14" rx="1"/>
      </svg>
      <svg class="icon-buffer" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" width="14" height="14">
        <circle cx="10" cy="10" r="7" stroke-dasharray="22" stroke-dashoffset="22">
          <animateTransform attributeName="transform" type="rotate" from="0 10 10" to="360 10 10" dur="0.8s" repeatCount="indefinite"/>
        </circle>
      </svg>
      <span class="audio-btn-label">Intro</span>
    </button>
    <noscript>
      <a href={`/audio/companions/${audio}.ogg`} class="audio-noscript-link">
        Listen to {name} introduction
      </a>
    </noscript>
  </div>

  <!-- Scroll hint: next agent name injected by JS -->
  <div class="scroll-hint" aria-hidden="true">
    <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <path d="M4 7l6 6 6-6"/>
    </svg>
  </div>
</section>

<style>
/* ── Section container ───────────────────────────────────────────── */
.agent-section {
  position: relative;
  width: 100%;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  scroll-snap-align: start;
  overflow: hidden;
  /* content-visibility for off-screen performance */
  content-visibility: auto;
  contain-intrinsic-size: 100vw 100vh;
}

/* ── Gradient background (mobile fallback + desktop tint) ── */
.agent-bg-gradient {
  position: absolute;
  inset: 0;
  background: radial-gradient(
    ellipse 80% 60% at 50% 40%,
    color-mix(in srgb, var(--agent-color) 8%, transparent) 0%,
    transparent 70%
  );
  pointer-events: none;
  z-index: 0;
}

/* ── Content wrapper ─────────────────────────────────────────────── */
.agent-content-wrap {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 900px;
  padding: 2rem 1.5rem;
  margin: 0 auto;
  display: flex;
  align-items: stretch;
  justify-content: center;
}

/* ── Scrim: backdrop for readability ─────────────────────────────── */
.agent-scrim {
  background: rgba(5, 8, 16, 0.65);
  backdrop-filter: blur(2px);
  -webkit-backdrop-filter: blur(2px);
  border-radius: 8px;
  padding: 2.5rem 2rem;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
}

/* ── Photo ───────────────────────────────────────────────────────── */
.agent-photo-wrap {
  position: relative;
  width: 190px;
  height: 190px;
  flex-shrink: 0;
}

.agent-photo {
  width: 190px;
  height: 190px;
  border-radius: 50%;
  object-fit: cover;
  object-position: center top;
  border: 2px solid var(--agent-color);
  box-shadow:
    0 0 0 4px color-mix(in srgb, var(--agent-color) 18%, transparent),
    0 0 32px color-mix(in srgb, var(--agent-color) 28%, transparent),
    0 8px 24px rgba(0, 0, 0, 0.5);
  display: block;
}

.agent-photo-fallback {
  width: 190px;
  height: 190px;
  border-radius: 50%;
  border: 2px solid var(--agent-color);
  box-shadow:
    0 0 0 4px color-mix(in srgb, var(--agent-color) 18%, transparent),
    0 0 32px color-mix(in srgb, var(--agent-color) 28%, transparent);
  background: rgba(5, 8, 16, 0.8);
  color: var(--agent-color);
  font-size: 2.8rem;
  font-weight: 500;
  font-family: 'JetBrains Mono', monospace;
  display: none;
  align-items: center;
  justify-content: center;
  position: absolute;
  inset: 0;
}

/* ── Identity ────────────────────────────────────────────────────── */
.agent-identity {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  text-align: center;
}

.agent-name {
  font-family: 'Instrument Serif', Georgia, serif;
  font-size: clamp(1.6rem, 4vw, 2.2rem);
  font-weight: 400;
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin: 0;
  /* override global h2 top-margin */
  margin-top: 0 !important;
}

.agent-role-badge {
  font-size: 0.65rem;
  font-family: 'JetBrains Mono', monospace;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--agent-color);
  background: color-mix(in srgb, var(--agent-color) 12%, transparent);
  border: 1px solid color-mix(in srgb, var(--agent-color) 35%, transparent);
  border-radius: 2px;
  padding: 0.25rem 0.75rem;
  white-space: nowrap;
}

/* ── Tagline ─────────────────────────────────────────────────────── */
.agent-tagline {
  font-size: 0.95rem;
  font-style: italic;
  color: var(--fg-muted, rgba(200, 210, 220, 0.7));
  text-align: center;
  line-height: 1.5;
  margin: 0;
  max-width: 680px;
}

/* ── Bio ─────────────────────────────────────────────────────────── */
.agent-bio {
  font-size: 0.93rem;
  line-height: 1.8;
  color: var(--fg-dim, rgba(200, 215, 230, 0.88));
  text-align: left;
  margin: 0;
  max-width: 720px;
}

/* ── CTA (K-9 closer) ────────────────────────────────────────────── */
.closer-cta {
  margin-top: 2rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
}

.closer-cta-text {
  font-size: 0.95rem;
  color: var(--fg-muted, rgba(200, 210, 220, 0.7));
  margin: 0;
}

.closer-cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.9rem;
  font-family: 'JetBrains Mono', monospace;
  padding: 0.625rem 1.5rem;
  border: 1px solid var(--agent-color);
  border-radius: 3px;
  color: var(--agent-color);
  text-decoration: none;
  transition: background 150ms, color 150ms;
}

.closer-cta-btn:hover {
  background: color-mix(in srgb, var(--agent-color) 12%, transparent);
  color: white;
}

/* ── Tags ────────────────────────────────────────────────────────── */
.agent-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  justify-content: center;
  max-width: 680px;
}

.agent-tag {
  font-size: 0.68rem;
  font-family: 'JetBrains Mono', monospace;
  letter-spacing: 0.05em;
  color: color-mix(in srgb, var(--agent-color) 85%, white);
  background: color-mix(in srgb, var(--agent-color) 10%, transparent);
  border: 1px solid color-mix(in srgb, var(--agent-color) 25%, transparent);
  border-radius: 2px;
  padding: 0.2rem 0.55rem;
}

/* ── Audio indicator ─────────────────────────────────────────────── */
.audio-indicator {
  position: absolute;
  bottom: 1.5rem;
  right: 1.5rem;
  z-index: 10;
}

.audio-btn {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.45rem 0.75rem;
  background: rgba(5, 8, 16, 0.75);
  border: 1px solid color-mix(in srgb, var(--agent-color) 40%, transparent);
  border-radius: 20px;
  color: color-mix(in srgb, var(--agent-color) 90%, white);
  font-size: 0.7rem;
  font-family: 'JetBrains Mono', monospace;
  letter-spacing: 0.06em;
  cursor: pointer;
  transition: background 150ms, border-color 150ms, transform 100ms;
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
}

.audio-btn:hover {
  background: color-mix(in srgb, var(--agent-color) 15%, rgba(5, 8, 16, 0.85));
  border-color: color-mix(in srgb, var(--agent-color) 60%, transparent);
  transform: scale(1.04);
}

.audio-btn:focus-visible {
  outline: 2px solid var(--agent-color);
  outline-offset: 3px;
}

.audio-btn:active {
  transform: scale(0.98);
}

/* Icon visibility states — controlled by data-state on .audio-indicator */
.icon-pause,
.icon-buffer { display: none; }

.audio-indicator[data-state="playing"] .icon-play { display: none; }
.audio-indicator[data-state="playing"] .icon-pause { display: block; }

.audio-indicator[data-state="buffering"] .icon-play { display: none; }
.audio-indicator[data-state="buffering"] .icon-buffer { display: block; }

.audio-noscript-link {
  font-size: 0.75rem;
  color: var(--accent-primary, #00d2ff);
  text-decoration: underline;
}

/* ── Scroll hint ─────────────────────────────────────────────────── */
.scroll-hint {
  position: absolute;
  bottom: 1.5rem;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.2rem;
  opacity: 0.45;
  animation: scrollFloat 2.5s ease-in-out infinite;
  pointer-events: none;
}

.scroll-hint svg {
  color: var(--fg-muted, rgba(200, 215, 230, 0.65));
}

@keyframes scrollFloat {
  0%, 100% { transform: translateX(-50%) translateY(0); opacity: 0.35; }
  50% { transform: translateX(-50%) translateY(8px); opacity: 0.6; }
}

/* ── Mobile overrides ────────────────────────────────────────────── */
@media (max-width: 768px) {
  .agent-section {
    scroll-snap-align: none;
    content-visibility: visible;
  }

  .agent-photo-wrap,
  .agent-photo,
  .agent-photo-fallback { width: 140px; height: 140px; }

  .agent-scrim {
    padding: 2rem 1.25rem;
    gap: 0.875rem;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    background: rgba(5, 8, 16, 0.72);
  }

  .scroll-hint { display: none; }
}

/* ── Reduced motion ──────────────────────────────────────────────── */
@media (prefers-reduced-motion: reduce) {
  .agent-section { scroll-snap-align: none; }
  .scroll-hint { animation: none; opacity: 0.4; }
}
</style>
