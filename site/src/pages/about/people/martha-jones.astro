---
import ContentLayout from '../../../layouts/ContentLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import LinkButton from '../../../components/LinkButton.astro';
---

<ContentLayout
  title="Martha Jones — Policy & Standards Lead | Failure-First"
  description="Martha Jones is the Policy & Standards Lead at Failure-First. Regulatory submissions, policy briefs, and standards engagement."
  breadcrumbs={[
    { label: 'About', href: '/about/' },
    { label: 'People', href: '/about/people/' },
    { label: 'Martha Jones' },
  ]}
>
  <PageHeader
    title="Martha"
    tagline="Policy & Standards Lead"
  />

  <section>
    <div class="persona-card" style="--cc: #55efc4">
      <div class="persona-avatar-col">
        <img
          src="/images/companions/web_martha.jpg"
          alt="Martha Jones"
          class="persona-photo"
          onerror="this.style.display='none'"
        />
        <div class="persona-badge">Policy & Standards Lead</div>
      </div>

      <div class="persona-body">
        <p class="persona-tagline">
          "Evidence-based policy. Not advocacy. Not speculation. Evidence."
        </p>

        <!-- TODO: Martha — complete this section with your regulatory engagement approach, key frameworks you work with, and what good policy grounding looks like. See .claude/agents/martha.md for your role brief. -->
        <p class="todo-placeholder">
          [Profile content — Martha to complete in next session]
        </p>
      </div>
    </div>
  </section>

  <section>
    <h2>Regulatory Engagement</h2>
    <!-- TODO: Martha — summarise the stakeholder register (Tier 1-3), active engagements, and the Safe Work Australia urgency -->
    <p class="todo-placeholder">[Regulatory engagement overview — Martha to complete]</p>
  </section>

  <section>
    <h2>Current Priorities</h2>
    <!-- TODO: Martha — SWA technical brief (#173, March 2026 deadline), VAISS Guardrail 4, AU AISI engagement pathway -->
    <p class="todo-placeholder">[Current sprint priorities — Martha to complete]</p>
  </section>

  <section>
    <div class="nav-links">
      <LinkButton href="/about/people/" text="← All People" />
      <LinkButton href="/research/" text="Research" />
    </div>
  </section>
</ContentLayout>

<style>
  .persona-card {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 2.5rem;
    align-items: start;
    background: var(--bg-card);
    border: 1px solid color-mix(in srgb, var(--cc) 35%, var(--border-subtle));
    border-radius: 6px;
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
  }
  .persona-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 55% 45% at 0% 0%,
      color-mix(in srgb, var(--cc) 8%, transparent) 0%,
      transparent 100%
    );
    pointer-events: none;
  }
  @media (max-width: 580px) {
    .persona-card { grid-template-columns: 1fr; }
  }
  .persona-avatar-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
  .persona-photo {
    width: 130px;
    height: 130px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    border: 2px solid var(--cc);
    box-shadow:
      0 0 0 4px color-mix(in srgb, var(--cc) 15%, transparent),
      0 0 28px color-mix(in srgb, var(--cc) 25%, transparent);
  }
  .persona-badge {
    font-size: 0.62rem;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--cc);
    background: color-mix(in srgb, var(--cc) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--cc) 30%, transparent);
    border-radius: 2px;
    padding: 0.2rem 0.6rem;
    text-align: center;
  }
  .persona-tagline {
    font-style: italic;
    color: var(--fg-muted);
    font-size: 0.93rem;
    line-height: 1.7;
    border-left: 2px solid var(--cc);
    padding-left: 1rem;
    margin-bottom: 1.25rem;
  }
  .todo-placeholder {
    color: var(--fg-muted);
    font-style: italic;
    font-size: 0.85rem;
    opacity: 0.6;
  }
  .nav-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
</style>
