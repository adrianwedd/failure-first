---
import ContentLayout from '../../../layouts/ContentLayout.astro';
import HeroSection from '../../../components/HeroSection.astro';
import LinkButton from '../../../components/LinkButton.astro';
---

<ContentLayout
  title="Sarah Jane Smith — External Relations Lead | Failure-First"
  description="Sarah Jane Smith is the External Relations Lead at Failure-First. Grant applications, regulatory submissions, conference engagement, and standards body outreach."
  breadcrumbs={[
    { label: 'About', href: '/about/' },
    { label: 'People', href: '/about/people/' },
    { label: 'Sarah Jane Smith' },
  ]}
>
  <HeroSection title="<em>Sarah</em> Jane" subtitle="External Relations Lead" animation="signal" accent="gold" />

  <section>
    <div class="persona-card" style="--cc: #f39c12">
      <div class="persona-avatar-col">
        <img
          src="/images/companions/web_sarah-jane-smith.webp"
          alt="Sarah Jane Smith"
          class="persona-photo"
          loading="lazy"
          onerror="this.style.display='none'"
        />
        <div class="persona-badge">External Relations Lead</div>
      </div>

      <div class="persona-body">
        <p class="persona-tagline">
          "The investigative journalist who opens doors"
        </p>

      </div>
      <audio class="persona-audio" autoplay src="/audio/companions/sarah_jane_smith_intro.wav"></audio>
    </div>
  </section>

  <section>
    <h2>What I Do</h2>
    <p>
      I turn internal research into external impact. Grant applications, regulatory submissions, conference papers, standards body outreach — every deliverable I produce is sign-off-ready. I find the right venue, understand what they need, and package our work to meet their requirements precisely. The operator reviews it and sends it, rather than rewriting it.
    </p>
  </section>

  <section>
    <h2>Key Contributions</h2>
    <ul class="contributions">
      <li>Prepared the Foresight Institute compute grant application — $25,000 for 1,400 GPU-hours to scale mechanistic interpretability experiments</li>
      <li>Contributed to the NIST AI Safety Institute Consortium with HANSE framework and FLIP methodology documentation</li>
      <li>Drafted the Standards Australia IT-043 expression of interest for ISO/IEC JTC 1/SC 42 participation on AI robustness standards</li>
      <li>Authored 7 tailored outreach emails to grant bodies, regulators, and standards organisations — each with venue-specific evidence packages</li>
      <li>Produced the investor brief translating research findings into commercial positioning for adversarial testing services</li>
    </ul>
  </section>


  <section>
    <div class="nav-links">
      <LinkButton href="/about/people/" text="&larr; All People" />
      <LinkButton href="/research/" text="Research" />
    </div>
  </section>
</ContentLayout>

<style>
  .persona-card {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 2.5rem;
    align-items: start;
    background: var(--bg-card);
    border: 1px solid color-mix(in srgb, var(--cc) 35%, var(--border-subtle));
    border-radius: 6px;
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
  }
  .persona-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 55% 45% at 0% 0%,
      color-mix(in srgb, var(--cc) 8%, transparent) 0%,
      transparent 100%
    );
    pointer-events: none;
  }
  @media (max-width: 580px) {
    .persona-card { grid-template-columns: 1fr; }
  }
  .persona-avatar-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
  .persona-photo {
    width: 130px;
    height: 130px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    border: 2px solid var(--cc);
    box-shadow:
      0 0 0 4px color-mix(in srgb, var(--cc) 15%, transparent),
      0 0 28px color-mix(in srgb, var(--cc) 25%, transparent);
  }
  .persona-badge {
    font-size: 0.62rem;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--cc);
    background: color-mix(in srgb, var(--cc) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--cc) 30%, transparent);
    border-radius: 2px;
    padding: 0.2rem 0.6rem;
    text-align: center;
  }
  .persona-tagline {
    font-style: italic;
    color: var(--fg-muted);
    font-size: 0.93rem;
    line-height: 1.7;
    border-left: 2px solid var(--cc);
    padding-left: 1rem;
    margin-bottom: 1.25rem;
  }
  .contributions {
    list-style: none;
    padding: 0;
  }
  .contributions li {
    padding: 0.5rem 0 0.5rem 1.5rem;
    position: relative;
    color: var(--fg-dim);
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .contributions li::before {
    content: "\2192";
    position: absolute;
    left: 0;
    color: var(--cc, var(--accent-primary));
    font-family: 'JetBrains Mono', monospace;
  }
  .nav-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
</style>
