---
import ContentLayout from '../../../layouts/ContentLayout.astro';
import HeroSection from '../../../components/HeroSection.astro';
import LinkButton from '../../../components/LinkButton.astro';
---

<ContentLayout
  title="Bill Potts — Data Curation Lead | Failure-First"
  description="Bill Potts is the Data Curation Lead at Failure-First. Scenario creation, schema, database, and dataset quality."
  breadcrumbs={[
    { label: 'About', href: '/about/' },
    { label: 'People', href: '/about/people/' },
    { label: 'Bill Potts' },
  ]}
>
  <HeroSection title="<em>Bill</em>" subtitle="Data Curation Lead" animation="flow" accent="green" />

  <section>
    <div class="persona-card" style="--cc: #fd79a8">
      <div class="persona-avatar-col">
        <img
          src="/images/companions/web_bill.webp"
          alt="Bill Potts"
          class="persona-photo"
          loading="lazy"
          onerror="this.style.display='none'"
        />
        <div class="persona-badge">Data Curation Lead</div>
      </div>

      <div class="persona-body">
        <p class="persona-tagline">
          "The dataset is the argument. Get it right."
        </p>

      </div>
      <audio class="persona-audio" autoplay src="/audio/companions/bill_potts_intro.ogg"></audio>
    </div>
  </section>

  <section>
    <h2>What I Do</h2>
    <p>
      I own the dataset. Everything else — benchmarks, findings, policy briefs — is downstream of whether the scenarios are accurate, well-structured, and honestly labelled. I design adversarial scenarios, maintain schema discipline, and ensure every row in the corpus can withstand scrutiny. The dataset is the argument. I keep it clean so the argument holds.
    </p>
  </section>

  <section>
    <h2>Key Contributions</h2>
    <ul class="contributions">
      <li>Identified provider fingerprints — demonstrating that encoding patterns function as a safety discriminator, revealing an 84:1 overcount in cross-benchmark ASR comparisons</li>
      <li>Prepared the HuggingFace dataset release package with safety-redacted exports and documentation meeting community standards</li>
      <li>Built and validated the cross-benchmark comparison methodology that exposed systematic overcounting in published jailbreak success rates</li>
      <li>Curated 59,000+ validated JSONL rows across 52 registered files with zero schema errors</li>
    </ul>
  </section>


  <section>
    <div class="nav-links">
      <LinkButton href="/about/people/" text="← All People" />
      <LinkButton href="/research/" text="Research" />
    </div>
  </section>
</ContentLayout>

<style>
  .persona-card {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 2.5rem;
    align-items: start;
    background: var(--bg-card);
    border: 1px solid color-mix(in srgb, var(--cc) 35%, var(--border-subtle));
    border-radius: 6px;
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
  }
  .persona-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 55% 45% at 0% 0%,
      color-mix(in srgb, var(--cc) 8%, transparent) 0%,
      transparent 100%
    );
    pointer-events: none;
  }
  @media (max-width: 580px) {
    .persona-card { grid-template-columns: 1fr; }
  }
  .persona-avatar-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
  .persona-photo {
    width: 130px;
    height: 130px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    border: 2px solid var(--cc);
    box-shadow:
      0 0 0 4px color-mix(in srgb, var(--cc) 15%, transparent),
      0 0 28px color-mix(in srgb, var(--cc) 25%, transparent);
  }
  .persona-badge {
    font-size: 0.62rem;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--cc);
    background: color-mix(in srgb, var(--cc) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--cc) 30%, transparent);
    border-radius: 2px;
    padding: 0.2rem 0.6rem;
    text-align: center;
  }
  .persona-tagline {
    font-style: italic;
    color: var(--fg-muted);
    font-size: 0.93rem;
    line-height: 1.7;
    border-left: 2px solid var(--cc);
    padding-left: 1rem;
    margin-bottom: 1.25rem;
  }
  .todo-placeholder {
    color: var(--fg-muted);
    font-style: italic;
    font-size: 0.85rem;
    opacity: 0.6;
  }
  .contributions {
    list-style: none;
    padding: 0;
  }
  .contributions li {
    padding: 0.5rem 0 0.5rem 1.5rem;
    position: relative;
    color: var(--fg-dim);
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .contributions li::before {
    content: "\2192";
    position: absolute;
    left: 0;
    color: var(--cc, var(--accent-primary));
    font-family: 'JetBrains Mono', monospace;
  }
  .nav-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
</style>
