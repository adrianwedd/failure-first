---
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Find related daily-paper post by matching arxiv ID
const postData = post.data as any;
const blogArxiv = postData.arxiv || postData.arxiv_id || '';
let relatedPaper = null;
if (blogArxiv) {
  const papers = await getCollection('dailyPaper');
  relatedPaper = papers.find((p) => !p.data.draft && p.data.arxiv === blogArxiv);
}
---

<BlogPostLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  tags={post.data.tags}
  image={post.data.image}
  audio={post.data.audio}
  video={post.data.video}
>
  {relatedPaper && (
    <aside class="related-paper-cta">
      <p>
        <strong>Paper overview:</strong> See the Daily Paper entry for
        <a href={`/daily-paper/${relatedPaper.id}/`}>arXiv:{blogArxiv}</a>
        — includes audio overview and infographic.
      </p>
    </aside>
  )}
  <Content />
</BlogPostLayout>
