---
import ResearchLayout from '../../../layouts/ResearchLayout.astro';
import HeroSection from '../../../components/HeroSection.astro';
import { getCollection } from 'astro:content';

const allReports = await getCollection('reports', ({ data }) => !data.draft);
const reports = allReports.sort((a, b) => b.data.reportNumber - a.data.reportNumber);

const classificationColors: Record<string, string> = {
  "Regulatory Review": "var(--failure-warning)",
  "Standards Development": "var(--recovery-active)",
  "Research — AI Safety Policy": "var(--accent-primary)",
  "Technical Analysis": "var(--recovery-stable)",
  "Research — Empirical Study": "var(--accent-primary)",
  "HIGH": "var(--failure-warning)",
  "SAFETY-CRITICAL": "#ff4444",
};
---

<ResearchLayout
  title="Policy Brief Reports | Research | Failure-First"
  description={`${reports.length} policy reports on embodied AI safety policy, standards, and regulation. Part of the F41LUR3-F1R57 research corpus.`}
  breadcrumbs={[{ label: "Research", href: "/research/" }, { label: "Policy Reports" }]}
  status="active"
>
  <HeroSection
    title="Research<br /><em>reports</em>"
    subtitle={`${reports.length} reports across regulation, standards, research, and technical analysis`}
    animation="cascade"
  />

  <a href="/research/reports/synthesis/" class="synthesis-banner">
    <div class="synthesis-label">Synthesis</div>
    <div class="synthesis-content">
      <h3>Policy Corpus Synthesis</h3>
      <p>Cross-cutting analysis across Reports 21-32: 5 converging insights from 12 independently researched reports.</p>
    </div>
    <span class="synthesis-arrow" aria-hidden="true">&rarr;</span>
  </a>

  <section class="report-grid">
    {reports.map((r) => (
      <a href={`/research/reports/${r.id}/`} class="report-card">
        <div class="report-header">
          <span class="report-num">#{r.data.reportNumber}</span>
          <span class="report-class" style={`color: ${classificationColors[r.data.classification] || 'inherit'}`}>
            {r.data.classification}
          </span>
        </div>
        <h3>{r.data.title}</h3>
        <time>{r.data.date instanceof Date ? r.data.date.toISOString().split('T')[0] : r.data.date}</time>
      </a>
    ))}
  </section>
</ResearchLayout>

<style>
  .synthesis-banner {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem;
    margin-top: 1.5rem;
    border: 1px solid var(--accent-primary, #00d2ff);
    border-radius: 6px;
    text-decoration: none;
    color: inherit;
    background: rgba(0, 210, 255, 0.04);
    transition: border-color 0.2s, background 0.2s, transform 0.15s;
  }

  .synthesis-banner:hover {
    background: rgba(0, 210, 255, 0.08);
    transform: translateY(-2px);
  }

  .synthesis-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--bg, #050810);
    background: var(--accent-primary, #00d2ff);
    padding: 0.25rem 0.5rem;
    border-radius: 3px;
    flex-shrink: 0;
  }

  .synthesis-content {
    flex: 1;
    min-width: 0;
  }

  .synthesis-content h3 {
    font-size: 1rem;
    margin: 0 0 0.25rem 0;
  }

  .synthesis-content p {
    font-size: 0.8125rem;
    margin: 0;
    color: var(--fg-dim, #b0b8c5);
  }

  .synthesis-arrow {
    font-size: 1.25rem;
    color: var(--accent-primary, #00d2ff);
    flex-shrink: 0;
  }

  .report-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  .report-card {
    display: block;
    padding: 1.25rem;
    border: 1px solid var(--border-color, #333);
    border-radius: 6px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, transform 0.15s;
  }

  .report-card:hover {
    border-color: var(--accent-primary, #f59e0b);
    transform: translateY(-2px);
  }

  .report-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .report-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--accent-primary, #f59e0b);
  }

  .report-class {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .report-card h3 {
    font-size: 1rem;
    margin: 0 0 0.5rem 0;
    line-height: 1.4;
  }

  .report-card time {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--text-secondary, #888);
  }
</style>
