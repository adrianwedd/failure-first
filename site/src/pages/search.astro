---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
---

<BaseLayout title="Search" description="Search across all research, blog posts, daily papers, and documentation." noindex>
  <HeroSection title="Search<br /><em>everything</em>" subtitle="Find research, reports, policy analysis, and more" animation="weave" accent="cyan" />
  <section class="search-page">
    <div id="search" class="search-container"></div>
    <div id="search-skeleton" class="skeleton">
      <div class="skeleton-bar skeleton-input"></div>
      <div class="skeleton-results">
        <div class="skeleton-bar" style="width: 75%"></div>
        <div class="skeleton-bar" style="width: 100%"></div>
        <div class="skeleton-bar" style="width: 85%"></div>
      </div>
      <div class="skeleton-results">
        <div class="skeleton-bar" style="width: 65%"></div>
        <div class="skeleton-bar" style="width: 100%"></div>
        <div class="skeleton-bar" style="width: 80%"></div>
      </div>
    </div>
  </section>
</BaseLayout>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script is:inline>
  window.addEventListener('DOMContentLoaded', async () => {
    const script = document.createElement('script');
    script.src = '/pagefind/pagefind-ui.js';
    script.onload = () => {
      new PagefindUI({
        element: '#search',
        showSubResults: true,
        showImages: false,
      });
      var skeleton = document.getElementById('search-skeleton');
      if (skeleton) skeleton.remove();
    };
    document.head.appendChild(script);
  });

  // Keyboard shortcut: press "/" to focus search
  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && !e.ctrlKey && !e.metaKey && !e.altKey) {
      const active = document.activeElement;
      if (active && (active.tagName === 'INPUT' || active.tagName === 'TEXTAREA')) return;
      e.preventDefault();
      const input = document.querySelector('.pagefind-ui__search-input');
      if (input) input.focus();
    }
  });
</script>

<style>
  .search-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  .skeleton {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .skeleton-bar {
    height: 0.75rem;
    background: var(--bg-card);
    border-radius: 4px;
    animation: pulse 1.5s ease-in-out infinite;
  }

  .skeleton-input {
    height: 3rem;
    border: 1px solid var(--border-subtle);
    border-radius: 0.5rem;
  }

  .skeleton-results {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 0.5rem;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.7; }
  }
</style>

<style is:global>
  /* Pagefind UI theme — maps to Failure-First tokens */
  :root {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: var(--accent-primary);
    --pagefind-ui-text: var(--fg);
    --pagefind-ui-background: var(--bg);
    --pagefind-ui-border: var(--border-subtle);
    --pagefind-ui-tag: var(--bg-card);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0.5rem;
    --pagefind-ui-font: inherit;
  }

  .pagefind-ui__search-input {
    background: var(--bg-elevated) !important;
    color: var(--fg) !important;
  }

  .pagefind-ui__search-input::placeholder {
    color: var(--fg-muted) !important;
  }

  .pagefind-ui__search-input:focus {
    outline: 2px solid var(--accent-primary) !important;
    outline-offset: 2px;
  }

  .pagefind-ui__result-link {
    color: var(--accent-primary) !important;
  }

  .pagefind-ui__result-link:hover {
    text-decoration: underline !important;
  }

  .pagefind-ui__result-excerpt {
    color: var(--fg-dim) !important;
  }

  .pagefind-ui__result-excerpt mark {
    background: var(--selection) !important;
    color: var(--fg) !important;
    padding: 0.1em 0.2em;
    border-radius: 2px;
  }

  .pagefind-ui__message {
    color: var(--fg-muted) !important;
  }

  .pagefind-ui__button {
    background: var(--bg-card) !important;
    color: var(--fg) !important;
    border-color: var(--border-subtle) !important;
  }

  .pagefind-ui__button:hover {
    border-color: var(--accent-primary) !important;
    color: var(--accent-primary) !important;
  }

  .pagefind-ui__result {
    border-color: var(--border-subtle) !important;
  }

  .pagefind-ui__result-title {
    color: var(--fg) !important;
  }
</style>
