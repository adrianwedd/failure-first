  note=&#123;Available at https://failurefirst.org&#125;
&#125;</code></pre>
    <p>See our <a href="/cite/">citation guide</a> for venue-specific formats.</p>
  </section>

</ContentLayout>

<style>
  .papers-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .paper-card {
    position: relative;
    border: 1px solid var(--border, #333);
    border-radius: 12px;
    padding: 2rem;
    background: var(--surface, #111);
    transition: border-color 0.2s;
  }

  .paper-card:hover {
    border-color: var(--accent, #8b5cf6);
  }

  .paper-card h2 {
    font-size: 1.3rem;
    margin: 0.5rem 0 1rem;
    line-height: 1.4;
  }

  .paper-venue,
  .paper-deadline,
  .paper-status-detail {
    font-size: 0.95rem;
    margin: 0.4rem 0;
    color: var(--text-muted, #999);
  }

  .paper-abstract {
    margin: 1rem 0;
    line-height: 1.7;
    font-size: 0.95rem;
  }

  .paper-status {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .paper-status.submitted {
    background: rgba(34, 197, 94, 0.15);
    color: #22c55e;
    border: 1px solid rgba(34, 197, 94, 0.3);
  }

  .paper-status.in-progress {
    background: rgba(234, 179, 8, 0.15);
    color: #eab308;
    border: 1px solid rgba(234, 179, 8, 0.3);
  }

  .paper-status.preprint {
    background: rgba(139, 92, 246, 0.15);
    color: #8b5cf6;
    border: 1px solid rgba(139, 92, 246, 0.3);
  }

  .paper-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .tag {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-size: 0.75rem;
    background: rgba(139, 92, 246, 0.1);
    color: var(--text-muted, #aaa);
    border: 1px solid rgba(139, 92, 246, 0.2);
  }

  .paper-downloads {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 1rem 0;
  }

  .download-link {
    display: inline-block;
    padding: 0.4rem 1rem;
    background: rgba(139, 92, 246, 0.15);
    color: #8b5cf6;
    border: 1px solid rgba(139, 92, 246, 0.3);
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s;
  }

  .download-link:hover {
    background: rgba(139, 92, 246, 0.25);
    text-decoration: none;
  }

  pre {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid var(--border, #333);
    border-radius: 8px;
    padding: 1rem;
    overflow-x: auto;
    font-size: 0.85rem;
  }
</style>
