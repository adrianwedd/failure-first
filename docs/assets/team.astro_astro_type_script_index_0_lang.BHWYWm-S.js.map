/* ── Mobile colour spacers ───────────────────────────────────────────────── */
// M3: Move spacer injection into a function, run on load AND debounced resize

function injectMobileSpacers() {
  // Remove any previously injected spacers before re-injecting
  document.querySelectorAll('.mobile-spacer').forEach((el) => el.remove());

  if (window.innerWidth > 768) return; // desktop — no spacers needed

  const sections = Array.from(document.querySelectorAll<HTMLElement>('.agent-section[data-accent-color]'));
  sections.forEach((section, i) => {
    if (i < sections.length - 1) {
      const colorA = section.dataset.accentColor ?? '#00d2ff';
      const colorB = (sections[i + 1] as HTMLElement).dataset.accentColor ?? '#00d2ff';
      const spacer = document.createElement('div');
