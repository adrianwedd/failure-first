    document.addEventListener('DOMContentLoaded', () => {
      const buttons = document.querySelectorAll('.new-filter');
      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          const filter = btn.getAttribute('data-filter');
          buttons.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');

          const cards = document.querySelectorAll('.new-card');
          cards.forEach(card => {
            if (filter === 'all' || card.getAttribute('data-type') === filter) {
              card.removeAttribute('data-hidden');
            } else {
              card.setAttribute('data-hidden', '');
            }
          });

          // Hide empty month sections
          document.querySelectorAll('.new-month').forEach(section => {
            const visible = section.querySelectorAll('.new-card:not([data-hidden])');
            if (visible.length === 0) {
              section.setAttribute('data-hidden', '');
            } else {
              section.removeAttribute('data-hidden');
            }
          });
        });
      });
    });
  


